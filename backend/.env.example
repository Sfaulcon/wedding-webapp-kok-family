PORT=4000
# LOG_LEVEL=DEBUG|INFO|WARN|ERROR (default: INFO)
# SPREADSHEET_ID=your-google-sheet-id
# BANKING_DETAILS=Bank name, Account name, Acc no, Branch (shown to venue guests)
# ALLOWED_ORIGINS=https://yourdomain.com (comma-separated, required for production)
# SYNC_SECRET=strong-random-string (required for manual sync in production)
