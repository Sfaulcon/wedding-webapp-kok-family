# Copy to .env and fill in values. Never commit .env or credentials.

NODE_ENV=development
PORT=4000
LOG_LEVEL=INFO

# Google Sheet ID (from the sheet URL)
SPREADSHEET_ID=

# CORS: comma-separated frontend URLs. Required in production.
# Production example: https://francoisandkaitlyn.co.za
ALLOWED_ORIGINS=http://localhost:5713,http://localhost:5173

# Manual sheet sync (POST /api with Bearer token). Required in production.
SYNC_SECRET=

# Optional: tune batched writes to Google Sheets
# SHEETS_WRITE_DELAY_MS=2000
# SHEETS_BATCH_SIZE_RSVP=20
# SHEETS_BATCH_SIZE_SONG=20

# Set to 1 if you use a reverse proxy and rate limits look wrong
# TRUST_PROXY=1
